# Neon PostgreSQL (production)
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Local Docker / PostgreSQL
DATABASE_URL=postgresql://jse_user:jse_password@db:5432/jse_analytics

JWT_SECRET=change-this-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
UPLOAD_DIR=uploads
APP_URL=http://localhost:8000

# Storage: local | s3 (Cloudflare R2 uses s3 + custom endpoint)
STORAGE_BACKEND=local
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@jse-analytics.com
BREVO_API_KEY=
APP_ENV=development
PLATFORM_OWNER_EMAIL=admin@bluemachines.com
PLATFORM_OWNER_PASSWORD=Admin123!

# Optional: LLM-assisted extraction (OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OCR_ENABLED=false

# Health alerts (emailed via Brevo when thresholds exceeded)
ALERT_FAILED_EXTRACTIONS_THRESHOLD=3
ALERT_PENDING_EXTRACTIONS_THRESHOLD=10
ALERT_EMAIL=

JOB_POLL_SECONDS=15
